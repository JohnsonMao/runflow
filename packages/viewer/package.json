{
  "name": "@runflow/viewer",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./server/index.ts",
      "import": {
        "development": "./server/index.ts",
        "default": "./dist/server/index.js"
      },
      "default": "./dist/server/index.js"
    }
  },
  "main": "./dist/server/index.js",
  "module": "./dist/server/index.js",
  "types": "./server/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx watch --conditions=development server/cli.ts",
    "build": "vite build && tsup",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --reporter=dot",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@runflow/convention-openapi": "workspace:^",
    "@runflow/core": "workspace:*",
    "@runflow/handlers": "workspace:^",
    "@runflow/workspace": "workspace:*",
    "chokidar": "catalog:prod",
    "clsx": "catalog:frontend",
    "dagre": "catalog:dev",
    "lucide-react": "catalog:frontend",
    "polka": "catalog:prod",
    "react": "catalog:frontend",
    "react-dom": "catalog:frontend",
    "reactflow": "catalog:frontend",
    "sirv": "catalog:prod",
    "tailwind-merge": "catalog:frontend",
    "ws": "catalog:prod"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@radix-ui/react-collapsible": "catalog:frontend",
    "@radix-ui/react-dialog": "catalog:frontend",
    "@radix-ui/react-select": "catalog:frontend",
    "@radix-ui/react-separator": "catalog:frontend",
    "@radix-ui/react-slot": "catalog:frontend",
    "@radix-ui/react-tabs": "catalog:frontend",
    "@radix-ui/react-tooltip": "catalog:frontend",
    "@tailwindcss/vite": "catalog:frontend",
    "@testing-library/react": "catalog:dev",
    "@types/dagre": "catalog:dev",
    "@types/polka": "catalog:dev",
    "@types/react": "catalog:frontend",
    "@types/react-dom": "catalog:frontend",
    "@types/ws": "catalog:dev",
    "@vitejs/plugin-react": "catalog:dev",
    "@vitest/coverage-v8": "catalog:dev",
    "class-variance-authority": "catalog:frontend",
    "eslint": "catalog:dev",
    "radix-ui": "catalog:frontend",
    "tailwindcss": "catalog:frontend",
    "tsup": "catalog:dev",
    "tsx": "catalog:dev",
    "tw-animate-css": "catalog:frontend",
    "typescript": "catalog:dev",
    "vite": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
