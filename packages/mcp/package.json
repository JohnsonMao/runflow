{
  "name": "@bricks/mcp",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "bricks": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc",
    "dev": "tsx watch src/cli.ts http",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "ts:check": "tsc --noEmit",
    "clean": "rimraf dist tsconfig.tsbuildinfo node_modules"
  },
  "dependencies": {
    "@bricks/flow": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "commander": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
