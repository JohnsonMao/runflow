{
  "name": "@bricks/flow",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc",
    "dev": "tsx watch src/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "ts:check": "tsc --noEmit",
    "clean": "rimraf dist tsconfig.tsbuildinfo node_modules"
  },
  "dependencies": {
    "@bricks/core": "workspace:*",
    "@bricks/nodes": "workspace:*",
    "js-yaml": "^4.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
