{
  "handlers": {
    "echo": "../custom-handler/echo-handler.mjs"
  },
  "flowsDir": "../flows",
  "params": {
    "env": "example",
    "name": "Guest",
    "count": 1
  },
  "openapi": {
    "simple": {
      "specPath": "../openapi/simple.yaml",
      "baseUrl": "https://api.example.com",
      "operationFilter": {
        "method": "get"
      },
      "hooks": [
        {
          "pattern": "^get-",
          "hooks": {
            "before": [
              { "type": "set", "set": { "prepared": true }, "dependsOn": [] }
            ],
            "after": [
              { "type": "set", "set": { "done": true } }
            ]
          }
        }
      ]
    }
  }
}
