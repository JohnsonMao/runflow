{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    "apps/*/src/**/*.test.ts",
    "apps/*/vitest.config.ts",
    "eslint.config.mjs",
    "packages/*/src/**/*.test.ts",
    "packages/*/vitest.config.ts",
    "scripts/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
